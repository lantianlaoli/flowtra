# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Required for creator video import analysis (video_url direct mode, no base64 fallback)
OPENROUTER_ANALYSIS_VIDEO_MODEL=
# Optional: comma-separated OpenRouter providers to ignore for creator video analysis (e.g. "alibaba")
OPENROUTER_ANALYSIS_VIDEO_IGNORE_PROVIDERS=
# Model for TikTok URL video analysis (landing page, showcase, console TikTok input)
TEMP_ANALYSIS_VIDEO_OPENROUTER_MODEL=

# KIE API (AI Image/Video Generation)
KIE_API_KEY=
KIE_CREDIT_THRESHOLD=

# Creem Payment
CREEM_ENVIRONMENT=
CREEM_API_URL_DEV=
CREEM_API_URL_PROD=
CREEM_API_KEY_DEV=
CREEM_API_KEY_PROD=

# Subscription Product IDs (Monthly)
# Note: Using PACK naming for backward compatibility
# These are subscription products, not one-time purchases
# Lite Subscription
LITE_PACK_CREEM_DEV_ID=
LITE_PACK_CREEM_PROD_ID=
# Basic Subscription
BASIC_PACK_CREEM_DEV_ID=
BASIC_PACK_CREEM_PROD_ID=
# Pro Subscription
PRO_PACK_CREEM_DEV_ID=
PRO_PACK_CREEM_PROD_ID=

# Contact & Social Media
NEXT_PUBLIC_X=
NEXT_PUBLIC_LINKEDIN=
NEXT_PUBLIC_TIKTOK=
NEXT_PUBLIC_THREADS=
NEXT_PUBLIC_EMAIL=
NEXT_PUBLIC_INSTAGRAM=
NEXT_PUBLIC_DISCORD=
NEXT_PUBLIC_YOUTUBE=

# Site Configuration
# Public site URL - REQUIRED for webhooks (KIE API, fal.ai)
# Production: https://flowtra.ai
# Local dev with webhooks: Use ngrok URL (e.g., https://abc123.ngrok-free.app)
# Local dev without webhooks: Leave empty (will use polling fallback if available)
NEXT_PUBLIC_SITE_URL=

# Resend Email
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
RESEND_FROM=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY_ENABLED=
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY_SAMPLE_RATE=

# FAL AI
FAL_KEY=

# TikTok API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# Cron job security (optional)
# Generate a random secret for authenticating cron job requests if needed
# Example: openssl rand -base64 32
# Leave empty if you don't need authentication (Supabase cron is internal)
CRON_SECRET=

# OpenCode MCP Servers
# Supabase MCP (required for database operations via MCP)
SUPABASE_ACCESS_TOKEN=
# Context7 API Key (optional - for searching technical documentation)
CONTEXT7_API_KEY=
